# chatbot 環境変数テンプレート
# このファイルをコピーして .env を作成し、各値を埋めてください
# cp .env.example .env

# ── Google API ──────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_ACCESS_TOKEN=your_google_access_token
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_WRITE_REFRESH_TOKEN=your_google_write_refresh_token

# ── LINE ────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_TOKEN=your_line_token
LINE_USER_ID=your_line_user_id
LINE_GROUP_ID=your_line_group_id
LINE_BOT_SERVER_URL=https://your-bot-server.example.com

# ── Anthropic ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── Spreadsheet IDs ─────────────────────
STORES_SPREADSHEET_ID=your_stores_sheet_id
STORES_SHEET_NAME=Sheet1
GEPPO_SHEET_ID=your_geppo_sheet_id
FUWAMOKO_GEPPO_ID=your_fuwamoko_geppo_id
KOMOJU_SHEET_ID=your_komoju_sheet_id
MEISAI_TEST_ID=your_meisai_test_id
# クライアント仕様店舗（T-1043 Angel Spa等）の【明細】LINE動作確認用テストシートID。
# 設定時、parsed.isClient=true のリクエストのみ findSpreadsheetByDateStr がこのIDを返す。
# 他のT-XXX店舗の本番運用には一切影響しない（MEISAI_TEST_ID と独立）。
MEISAISYO_CLIENT_TEST_ID=your_client_test_spreadsheet_id
DATA_FOLDER_ID=your_drive_folder_id
STORE_IMAGE_FOLDER_ID=your_image_folder_id

# ── KOMOJU 決済 ──────────────────────────
KOMOJU_URL_STARTER=https://komoju.com/ja/...
KOMOJU_URL_STANDARD=https://komoju.com/ja/...
KOMOJU_URL_PREMIUM=https://komoju.com/ja/...
KOMOJU_WEBHOOK_SECRET=your_komoju_webhook_secret

# ── 外部サービス ─────────────────────────
CREA_ACCESS=your_crea_access_token
FUWA_ACCESS=your_fuwa_access_token

# ── ダッシュボード / 認証 ───────────────
DASHBOARD_TOKEN=your_dashboard_token
SEO_CHECK_TOKEN=your_seo_check_token

# ── サーバー ────────────────────────────
PORT=3000
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ── 店舗単位の動作設定（multi_worker起動時に動的注入） ──
# 以下は worker プロセスごとに動的に渡される変数なので
# .env に書く必要はないが、参考までに列挙しておく
STORE_NAME=
STORE_USER=
STORE_PASS=
STORE_SHOP_ID=
STORE_RESERVE_URL=
STORE_START_TIME=09:00
STORE_END_TIME=24:00
STORE_ANNNAI_MIN=1
STORE_ANNNAI_SEC=0
STORE_REALTIME_MIN=10
STORE_REALTIME_SEC=0
STORE_KYUJIN_MIN=10
STORE_KYUJIN_SEC=0
STORE_TEMPLATE_KEYWORD=
STORE_TAIKEN_ENABLED=false
STORE_SHINSHA_ENABLED=false
STORE_SHINSHA_TITLE=
STORE_BLOG_ENABLED=false
STORE_BLOG_TITLE=
STORE_BLOG_CONTENT=
STORE_PROXY_HOST=
STORE_PROXY_PORT=
STORE_PROXY_USER=
STORE_PROXY_PASS=
ESTAMA_USER=
ESTAMA_PASS=

# ─── 代理店入稿フォーム（2026-07-24 追加）───
AGENCY_INTAKE_SHEET_ID=
AGENCY_INTAKE_SHEET_TAB=入稿台帳
AGENCY_GMAIL_USER=telaria.ltd@gmail.com
AGENCY_GMAIL_APP_PASSWORD=
AGENCY_NOTIFY_SELF=telaria.ltd@gmail.com
AGENCY_NOTIFY_PRIMARY=
